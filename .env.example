# Supabase — from your project's Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Server-only. Settings → API → service_role secret. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# OpenAI — used for chat completions and embeddings (server-only)
OPENAI_API_KEY=sk-your-openai-key

# Public base URL of this app (used by the embeddable widget)
NEXT_PUBLIC_APP_URL=http://localhost:3000
